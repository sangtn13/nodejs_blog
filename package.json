  "description": "",
  "lint-staged": {
    "src/**/*.js": [
      "prettier --single-quote --trailing-comma all --tab-width 2 --write"
    ],
    "src/**/*.css": [
      "prettier --single-quote --trailing-comma all --tab-width 2 --write"
