<div class="container-fluid mt-4">
  <div class="row">
    
    <!-- Left Sidebar - Categories -->
    <div class="col-lg-3 col-md-4 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0">
            <i class="bi bi-list-ul"></i> Danh mục
          </h5>
        </div>
        <div class="card-body p-0">
          <div class="list-group list-group-flush">
            <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
              Học âm
              <span class="badge bg-secondary rounded-pill">15</span>
            </a>
            <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
              Sweet Music
              <span class="badge bg-secondary rounded-pill">8</span>
            </a>
            <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
              Cầm âm
              <span class="badge bg-secondary rounded-pill">12</span>
            </a>
            <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
              Học đàn
              <span class="badge bg-secondary rounded-pill">20</span>
            </a>
            <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
              Khóa học
              <span class="badge bg-secondary rounded-pill">25</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Tags Cloud -->
      <div class="card shadow-sm mt-4">
        <div class="card-header bg-info text-white">
          <h5 class="mb-0">
            <i class="bi bi-tags"></i> Thẻ phổ biến
          </h5>
        </div>
        <div class="card-body">
          <div class="tag-cloud">
            <span class="badge bg-light text-dark m-1 p-2">Đàn Guitar</span>
            <span class="badge bg-light text-dark m-1 p-2">Piano</span>
            <span class="badge bg-light text-dark m-1 p-2">Violin</span>
            <span class="badge bg-light text-dark m-1 p-2">Drum</span>
            <span class="badge bg-light text-dark m-1 p-2">Bass</span>
            <span class="badge bg-light text-dark m-1 p-2">Nhạc lý</span>
            <span class="badge bg-light text-dark m-1 p-2">Hòa âm</span>
            <span class="badge bg-light text-dark m-1 p-2">Sáng tác</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="col-lg-6 col-md-8">
      
      <!-- Popular Posts Section -->
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-success text-white">
          <h4 class="mb-0">
            <i class="bi bi-fire"></i> HỢP ÂM MỚI
          </h4>
        </div>
        <div class="card-body">
          <div class="row">
            {{#each popularPosts}}
            <div class="col-md-6 mb-3">
              <div class="card h-100 border-0 bg-light">
                <div class="card-body p-3">
                  <h6 class="card-title text-primary">{{this.title}}</h6>
                  <p class="card-text small text-muted">{{this.description}}</p>
                  <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted">{{this.views}} lượt xem</small>
                    <span class="badge bg-warning text-dark">{{this.price}}</span>
                  </div>
                </div>
              </div>
            </div>
            {{/each}}
          </div>
        </div>
      </div>

      <!-- Sheet Music Section -->
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-dark">
          <h4 class="mb-0">
            <i class="bi bi-music-note-beamed"></i> SHEET NHẠC CÓ LỜI
          </h4>
        </div>
        <div class="card-body">
          <div class="list-group list-group-flush">
            {{#each sheetMusic}}
            <div class="list-group-item d-flex justify-content-between align-items-center">
              <div>
                <h6 class="mb-1 text-primary">{{this.title}}</h6>
                <p class="mb-1 small text-muted">{{this.artist}}</p>
              </div>
              <span class="badge bg-primary rounded-pill">{{this.price}}</span>
            </div>
            {{/each}}
          </div>
          <div class="text-center mt-3">
            <button class="btn btn-outline-warning">Xem thêm</button>
          </div>
        </div>
      </div>

      <!-- Guitar Section -->
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-danger text-white">
          <h4 class="mb-0">
            <i class="bi bi-music-note"></i> CẢM ÂM MỚI
          </h4>
        </div>
        <div class="card-body">
          <div class="list-group list-group-flush">
            {{#each guitarLessons}}
            <div class="list-group-item d-flex justify-content-between align-items-center">
              <div>
                <h6 class="mb-1 text-primary">{{this.title}}</h6>
                <p class="mb-1 small text-muted">{{this.description}}</p>
              </div>
              <span class="badge bg-danger rounded-pill">{{this.price}}</span>
            </div>
            {{/each}}
          </div>
          <div class="text-center mt-3">
            <button class="btn btn-outline-danger">Xem thêm</button>
          </div>
        </div>
      </div>

    </div>

    <!-- Right Sidebar -->
    <div class="col-lg-3 d-none d-lg-block">
      
      <!-- Latest Posts -->
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-secondary text-white">
          <h5 class="mb-0">
            <i class="bi bi-clock"></i> XEM NHIỀU NHẤT
          </h5>
        </div>
        <div class="card-body p-0">
          <div class="list-group list-group-flush">
            {{#each trendingPosts}}
            <div class="list-group-item">
              <div class="d-flex justify-content-between align-items-start">
                <div class="flex-grow-1">
                  <h6 class="mb-1 small">{{this.title}}</h6>
                  <p class="mb-1 text-muted small">{{this.category}}</p>
                </div>
                <small class="text-primary">{{this.views}}</small>
              </div>
            </div>
            {{/each}}
          </div>
        </div>
      </div>

      <!-- Course Promotion -->
      <div class="card shadow-sm mb-4 border-primary">
        <div class="card-header bg-primary text-white text-center">
          <h5 class="mb-0">
            <i class="bi bi-gift"></i> KHÓA HỌC HOT
          </h5>
        </div>
        <div class="card-body text-center">
          <div class="course-image-placeholder bg-primary text-white rounded mb-3 d-flex align-items-center justify-content-center" style="height: 150px;">
            <i class="bi bi-music-note-beamed" style="font-size: 3rem;"></i>
          </div>
          <h6 class="text-primary">Khóa học Guitar từ cơ bản đến nâng cao</h6>
          <p class="small text-muted">Học guitar hiệu quả với phương pháp độc quyền</p>
          <div class="price mb-3">
            <span class="text-decoration-line-through text-muted">1,500,000đ</span>
            <span class="text-danger h5 ms-2">999,000đ</span>
          </div>
          <button class="btn btn-primary btn-sm">Đăng ký ngay</button>
        </div>
      </div>

      <!-- Educational Content -->
      <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
          <h5 class="mb-0">
            <i class="bi bi-book"></i> GIÁO TRÌNH HỌC ĐÀN
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-2">
            <div class="col-6">
              <div class="card border-0 bg-light">
                <div class="card-body p-2 text-center">
                  <div class="bg-success text-white rounded mb-2 d-flex align-items-center justify-content-center" style="height: 60px;">
                    <i class="bi bi-music-note"></i>
                  </div>
                  <h6 class="small mb-1">Tổng hợp các hợp âm với thế Tone A</h6>
                  <span class="badge bg-success">Free</span>
                </div>
              </div>
            </div>
            <div class="col-6">
              <div class="card border-0 bg-light">
                <div class="card-body p-2 text-center">
                  <div class="bg-warning text-dark rounded mb-2 d-flex align-items-center justify-content-center" style="height: 60px;">
                    <i class="bi bi-piano"></i>
                  </div>
                  <h6 class="small mb-1">Hợp âm Piano cơ bản</h6>
                  <span class="badge bg-warning text-dark">99k</span>
                </div>
              </div>
            </div>
            <div class="col-6">
              <div class="card border-0 bg-light">
                <div class="card-body p-2 text-center">
                  <div class="bg-info text-white rounded mb-2 d-flex align-items-center justify-content-center" style="height: 60px;">
                    <i class="bi bi-hand-index"></i>
                  </div>
                  <h6 class="small mb-1">Cách chặn phím và đặt ngón tay đàn guitar</h6>
                  <span class="badge bg-info">199k</span>
                </div>
              </div>
            </div>
            <div class="col-6">
              <div class="card border-0 bg-light">
                <div class="card-body p-2 text-center">
                  <div class="bg-primary text-white rounded mb-2 d-flex align-items-center justify-content-center" style="height: 60px;">
                    <i class="bi bi-book"></i>
                  </div>
                  <h6 class="small mb-1">Học đàn Guitar đơn nhất - Bài 1</h6>
                  <span class="badge bg-primary">299k</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

  </div>
</div>

<style>
.tag-cloud .badge:hover {
  background-color: #0d6efd !important;
  color: white !important;
  cursor: pointer;
}

.list-group-item:hover {
  background-color: #f8f9fa;
}

.card {
  transition: transform 0.2s;
}

.card:hover {
  transform: translateY(-2px);
}

@media (max-width: 768px) {
  .container-fluid {
    padding: 0 10px;
  }
  
  .col-lg-3 {
    order: 3;
  }
  
  .col-lg-6 {
    order: 1;
  }
}
</style>
