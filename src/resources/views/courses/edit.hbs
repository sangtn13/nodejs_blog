<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
          <h4 class="mb-1">Cập nhật khóa học</h4>
        </div>
        <div class="card-body">
          <form action="/courses/{{course._id}}?_method=PUT" method="POST">
            <div class="form-group">
              <label for="name">Tên khóa học</label>
              <input type="text" class="form-control" value="{{course.name}}" id="name" name="name" placeholder="Nhập tên khóa học" required>
            </div>
            <div class="form-group">
              <label for="description">Mô tả</label>
              <textarea class="form-control" value="{{course.description}}" id="description" name="description" rows="3" placeholder="Nhập mô tả khóa học" required>{{course.description}}</textarea>
            </div>
            <div class="form-group">
              <label for="image">Ảnh đại diện (URL)</label>
              <input type="url" class="form-control" value="{{course.image}}" id="image" name="image" placeholder="Nhập link ảnh đại diện" required>
            </div>
            <button type="submit" class="btn btn-success btn-block">Cập nhật khóa học</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>