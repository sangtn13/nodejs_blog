<div class="container mt-5">
  <h2 class="mb-4">Quản lý khóa học của tôi</h2>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <a href="/me/trash/courses" class="btn btn-secondary">Thùng rác ({{deletedCount}})</a>
    {{#if courses.length}}
      <div class="d-flex align-items-center">
        <select class="form-control mr-2" style="width: auto;" id="bulkActionSelect">
          <option value="">-- Hành động --</option>
          <option value="delete">Xóa đã chọn</option>
        </select>
        <button type="button" class="btn btn-success" onclick="executeBulkAction()">Thực hiện</button>
      </div>
    {{/if}}
  </div>
  {{#if courses.length}}
  <form method="POST" action="/courses/bulk-action" id="bulkForm">
      <table class="table table-bordered table-hover table-striped">
        <thead class="thead-dark">
          <tr>
            <th scope="col"><input type="checkbox" id="checkAll" /></th>
            <th scope="col">#</th>
            <th scope="col">Tên khóa học</th>
            <th scope="col">Mô tả</th>
            <th scope="col">Ảnh</th>
            <th scope="col">Ngày tạo</th>
            <th scope="col">Ngày cập nhật</th>
            <th scope="col" style="width: 140px;">Hành động</th>
          </tr>
        </thead>
        <tbody>
          {{#each courses}}
            <tr>
              <td><input type="checkbox" name="courseIds[]" value="{{_id}}" /></td>
              <th scope="row">{{inc @index}}</th>
              <td>{{name}}</td>
              <td>{{description}}</td>
              <td>
                <img src="{{image}}" alt="{{name}}" style="width: 80px; height: auto;" />
              </td>
              <td>{{formatDate createdAt}}</td>
              <td>{{formatDate updatedAt}}</td>
              <td>
                <button
                  type="button"
                  class="btn btn-sm btn-outline-primary"
                  onclick="window.location.href='/courses/{{_id}}/edit'"
                  title="Sửa"
                  style="margin-right: 4px;"
                >
                  <i class="bi bi-pencil-square"></i>
                </button>
                <button
                  type="button"
                  class="btn btn-sm btn-outline-danger"
                  onclick="deleteItem('{{_id}}')"
                  title="Xóa"
                >
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
  </form>
  {{else}}
    <div class="alert alert-info text-center">
      Bạn chưa có khóa học nào.
      <a href="/courses/create" class="alert-link">Tạo khóa học mới</a>
    </div>
  {{/if}}
</div>
<script src="/js/bulk-action.js"></script>
<script>


  // Execute bulk action
  function executeBulkAction() {
    var select = document.getElementById('bulkActionSelect');
    var action = select.value;
    
    if (!action) {
      alert('Vui lòng chọn hành động!');
      return;
    }

    var checkedBoxes = document.querySelectorAll('input[name="courseIds[]"]:checked');
    if (checkedBoxes.length === 0) {
      alert('Vui lòng chọn ít nhất một khóa học!');
      return;
    }

    if (action === 'delete') {
      if (confirm('Bạn chắc chắn muốn xóa các khóa học đã chọn?')) {
        // Submit form with bulk action
        var form = document.querySelector('form[action="/courses/bulk-action"]');
        var actionInput = document.createElement('input');
        actionInput.type = 'hidden';
        actionInput.name = 'action';
        actionInput.value = 'delete';
        form.appendChild(actionInput);
        form.submit();
      }
    }
  }

  // Delete individual item
  function deleteItem(courseId) {
    if (confirm('Bạn chắc chắn muốn xóa?')) {
      var form = document.createElement('form');
      form.method = 'POST';
      form.action = '/courses/' + courseId + '?_method=DELETE';
      document.body.appendChild(form);
      form.submit();
    }
  }

        // Show toast if there's a message
  {{#if toastMessage}}
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof showToast === 'function') {
        showToast('{{toastMessage.type}}', '{{{toastMessage.message}}}');
      } else {
        alert('{{toastMessage.type}}: {{{toastMessage.message}}}'); // Fallback
      }
    });
  {{/if}}

</script>