<div class="container mt-5">
  <h2 class="mb-4">Khóa học đã xóa</h2>
    <div class="d-flex justify-content-between align-items-center mb-3">
    <a href="/me/stored/courses" class="btn btn-secondary">Danh sách khóa học</a>
    {{#if courses.length}}
      <div class="d-flex align-items-center">
        <select class="form-control mr-2" style="width: auto;" id="bulkActionSelect">
          <option value="">-- Hành động --</option>
          <option value="restore">Khôi phục đã chọn</option>
          <option value="force-delete">Xóa vĩnh viễn đã chọn</option>
        </select>
        <button type="button" class="btn btn-success" onclick="executeBulkAction()">Thực hiện</button>
      </div>
    {{/if}}
  </div>
  {{#if courses.length}}
    <form method="POST" action="/courses/bulk-action"  id="bulkForm">
      <table class="table table-bordered table-hover table-striped">
        <thead class="thead-dark">
          <tr>
            <th scope="col"><input type="checkbox" id="checkAll" /></th>
            <th scope="col">#</th>
            <th scope="col">Tên khóa học</th>
            <th scope="col">Mô tả</th>
            <th scope="col">Ảnh</th>
            <th scope="col">Ngày xóa</th>
            <th scope="col">Trạng thái</th>
            <th scope="col" style="width: 180px;">Hành động</th>
          </tr>
        </thead>
        <tbody>
          {{#each courses}}
            <tr>
              <td><input
                  type="checkbox"
                  name="courseIds[]"
                  value="{{_id}}"
                /></td>
              <th scope="row">{{inc @index}}</th>
              <td>{{name}}</td>
              <td>{{description}}</td>
              <td>
                <img
                  src="{{image}}"
                  alt="{{name}}"
                  style="width: 80px; height: auto;"
                />
              </td>
              <td>{{formatDate deletedAt}}</td>
              <td><span class="badge badge-danger">Đã xóa</span></td>
              <td>
                  <button
                    type="button"
                    class="btn btn-sm btn-outline-success restore-btn"
                    onclick="restoreItem('{{_id}}')"
                    title="Khôi phục"
                    style="margin-right: 4px;"
                  >
                    <i class="bi bi-arrow-counterclockwise"></i>
                  </button>
                  <button
                    type="button"
                    class="btn btn-sm btn-outline-danger"
                    onclick="forceDeleteItem('{{_id}}')"
                    title="Xóa vĩnh viễn"
                  >
                    <i class="bi bi-trash"></i>
                  </button>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </form>
  {{else}}
    <div class="alert alert-info text-center">
      Không có khóa học nào trong thùng rác.
      <a href="/me/stored/courses" class="alert-link">Quay lại trang quản lý
        khóa học</a>
    </div>
  {{/if}}
</div>
<script src="/js/bulk-action.js"></script>
<script>
  

  // Execute bulk action
  function executeBulkAction() {
    var select = document.getElementById('bulkActionSelect');
    var action = select.value;
    
    if (!action) {
      alert('Vui lòng chọn hành động!');
      return;
    }

    var checkedBoxes = document.querySelectorAll('input[name="courseIds[]"]:checked');
    if (checkedBoxes.length === 0) {
      alert('Vui lòng chọn ít nhất một khóa học!');
      return;
    }

    var confirmMessage = '';
    if (action === 'restore') {
      confirmMessage = 'Bạn chắc chắn muốn khôi phục các khóa học đã chọn?';
    } else if (action === 'force-delete') {
      confirmMessage = 'Bạn chắc chắn muốn xóa vĩnh viễn các khóa học đã chọn?';
    }

    if (confirm(confirmMessage)) {
      var form = document.querySelector('form[action="/courses/bulk-action"]');
      if (form) {
        // Remove existing action input if any
        var existingInput = form.querySelector('input[name="action"]');
        if (existingInput) {
          existingInput.remove();
        }
        
        // Add new action input
        var actionInput = document.createElement('input');
        actionInput.type = 'hidden';
        actionInput.name = 'action';
        actionInput.value = action;
        form.appendChild(actionInput);
        form.submit();
      } else {
        alert('Không tìm thấy form!');
      }
    }
  }

  // Restore individual item
  function restoreItem(courseId) {
    if (confirm('Khôi phục khóa học này?')) {
      var form = document.createElement('form');
      form.method = 'POST';
      form.action = '/courses/' + courseId + '/restore?_method=PATCH';
      document.body.appendChild(form);
      form.submit();
    }
  }

  // Force delete individual item
  function forceDeleteItem(courseId) {
    if (confirm('Xóa vĩnh viễn khóa học này?')) {
      var form = document.createElement('form');
      form.method = 'POST';
      form.action = '/courses/' + courseId + '/force?_method=DELETE';
      document.body.appendChild(form);
      form.submit();
    }
  }

        // Show toast if there's a message
  {{#if toastMessage}}
    document.addEventListener('DOMContentLoaded', function() {
      console.log('Toast message exists:', '{{toastMessage.type}}', '{{{toastMessage.message}}}');
      console.log('showToast function exists:', typeof showToast);
      
      if (typeof showToast === 'function') {
        showToast('{{toastMessage.type}}', '{{{toastMessage.message}}}');
      } else {
        console.error('showToast function not found!');
        alert('{{toastMessage.type}}: {{{toastMessage.message}}}'); // Fallback
      }
    });
  {{/if}}
</script>